<!-- include header -->
<%- include('include/_header') %>
<!-- /include header -->

<!-- Main Site -->
<%- include('partials/_nav') %>

<main class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Summary Cards -->
    <%- include('partials/_summary_cards') %>

    <!-- Judging Content -->
    <div class="bg-white rounded-lg shadow p-6">
      <% if (typeof schedule !== 'undefined' && schedule &&
      schedule.judgingSchedule) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% schedule.judgingSchedule.forEach((room, roomIndex) => { %>
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="text-lg font-medium mb-4">Room <%= roomIndex + 1 %></h3>
          <%- include('partials/_judging_schedule', { room }) %>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="p-4 text-center">
        <p>
          No judging schedule available. Please generate a schedule from the
          Configuration page.
        </p>
      </div>
      <% } %>
    </div>
  </div>
</main>

<!-- include footer -->
<%- include('include/_footer') %>
