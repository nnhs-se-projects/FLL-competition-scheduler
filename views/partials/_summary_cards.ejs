<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900">Robot Game Tables</h3>
    <p class="mt-2 text-3xl font-bold text-blue-600">
      <%= typeof schedule !== 'undefined' && schedule && schedule.tableRuns ?
      schedule.tableRuns.length : 0 %>
    </p>
    <p class="text-sm text-gray-500">Active Tables</p>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900">Judging Rooms</h3>
    <p class="mt-2 text-3xl font-bold text-blue-600">
      <%= typeof schedule !== 'undefined' && schedule &&
      schedule.judgingSchedule ? schedule.judgingSchedule.length : 0 %>
    </p>
    <p class="text-sm text-gray-500">Active Rooms</p>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900">Teams</h3>
    <p class="mt-2 text-3xl font-bold text-blue-600">
      <% if (typeof schedule !== 'undefined' && schedule &&
      schedule.teamsSchedule) { // Count actual teams (excluding empty entries)
      let teamCount = 0; for (let i = 0; i < schedule.teamsSchedule.length; i++)
      { if (schedule.teamsSchedule[i] && schedule.teamsSchedule[i].length > 0) {
      teamCount++; } } %> <%= teamCount %> <% } else { %> 0 <% } %>
    </p>
    <p class="text-sm text-gray-500">Participating Teams</p>
  </div>
</div>
