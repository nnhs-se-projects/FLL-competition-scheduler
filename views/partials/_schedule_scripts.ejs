<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Check if schedule exists before initializing
    <% if (typeof schedule !== 'undefined' && schedule && schedule.teamsSchedule) { %>
      // Initialize schedule data from server
      const scheduleData = {
        events: <%- JSON.stringify(schedule.teamsSchedule.flatMap((team, teamIndex) =>
          team.map(event => ({
            teamId: teamIndex,
            startTime: event.startTime,
            duration: event.duration,
            type: event.type,
            location: event.locationName
          }))
        )) %>,
        startTime: "<%= schedule.startTime || '08:00' %>"
      };

      // Pure JavaScript function to format time
      function formatTimeForDisplay(minutes) {
        // Parse the start time
        const startTimeStr = scheduleData.startTime || "08:00";
        const [startHours, startMinutes] = startTimeStr.split(':').map(Number);
        const startTotalMinutes = startHours * 60 + startMinutes;

        // Add the schedule minutes to the start time
        const totalMinutes = startTotalMinutes + minutes;

        // Convert back to hours and minutes
        const hours = Math.floor(totalMinutes / 60) % 24;
        const mins = totalMinutes % 60;

        // Format with leading zeros
        const formattedHours = hours.toString().padStart(2, '0');
        const formattedMinutes = mins.toString().padStart(2, '0');

        return `${formattedHours}:${formattedMinutes}`;
      }

      // Function to update the current event highlight
      function updateCurrentEvent() {
        // Get current time
        const now = new Date();

        // Calculate minutes since start time
        const [startHours, startMinutes] = scheduleData.startTime.split(':').map(Number);
        const startTotalMinutes = startHours * 60 + startMinutes;
        const currentTotalMinutes = now.getHours() * 60 + now.getMinutes();
        const minutesSinceStart = currentTotalMinutes - startTotalMinutes;

        // Find events happening now
        const currentEvents = scheduleData.events.filter(event => {
          const eventStart = event.startTime;
          const eventEnd = eventStart + event.duration;
          return minutesSinceStart >= eventStart && minutesSinceStart < eventEnd;
        });

        // Update UI to highlight current events
        document.querySelectorAll('.current-event').forEach(el => el.classList.remove('current-event'));

        currentEvents.forEach(event => {
          const eventElements = document.querySelectorAll(`[data-team-id="${event.teamId}"][data-start-time="${event.startTime}"]`);
          eventElements.forEach(el => el.classList.add('current-event'));
        });
      }

      // Update schedule stats
      function updateScheduleStats() {
        const totalTeams = scheduleData.events.reduce((acc, event) => {
          if (!acc.includes(event.teamId)) {
            acc.push(event.teamId);
          }
          return acc;
        }, []).length;

        const totalEvents = scheduleData.events.length;
        const eventTypes = scheduleData.events.reduce((acc, event) => {
          if (!acc[event.type]) {
            acc[event.type] = 0;
          }
          acc[event.type]++;
          return acc;
        }, {});

        console.log(`Schedule Stats: ${totalTeams} teams, ${totalEvents} total events`);
        console.log('Event Types:', eventTypes);
      }

      // Initialize
      updateCurrentEvent();
      setInterval(updateCurrentEvent, 60000); // Update every minute

      updateScheduleStats();
    <% } else { %>
      console.log('No schedule data available');
    <% } %>
  });
</script>

<style>
  .nav-link {
    @apply px-3 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md transition-colors;
  }
  .nav-link.active {
    @apply text-blue-600 bg-blue-50;
  }
  .current-event {
    background-color: rgba(59, 130, 246, 0.1);
    border-left: 4px solid #3b82f6;
  }
</style>
