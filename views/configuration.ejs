<!-- include header -->
<%- include('include/_header') %>
<!-- /include header -->

<!-- Main Site -->
<%- include('partials/_nav') %>

<main class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Success Message (hidden by default) -->
    <div
      id="successMessage"
      class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6 hidden"
    >
      <strong class="font-bold">Success!</strong>
      <span class="block sm:inline"
        >Schedule has been generated successfully.</span
      >
      <div class="mt-2">
        <a
          href="/"
          class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded"
        >
          View Schedule
        </a>
        <button
          id="dismissMessage"
          class="ml-2 inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded"
        >
          Dismiss
        </button>
      </div>
    </div>

    <!-- Configuration Form -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-2xl font-bold mb-6">Schedule Configuration</h2>

      <form id="configForm" class="space-y-6">
        <!-- Basic Configuration -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label
              for="numTeams"
              class="block text-sm font-medium text-gray-700"
              >Number of Teams</label
            >
            <input
              type="number"
              id="numTeams"
              name="numTeams"
              min="1"
              max="100"
              value="32"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>

          <div>
            <label
              for="numTables"
              class="block text-sm font-medium text-gray-700"
              >Number of Tables</label
            >
            <input
              type="number"
              id="numTables"
              name="numTables"
              min="1"
              max="10"
              value="4"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>

          <div>
            <label
              for="numJudgingRooms"
              class="block text-sm font-medium text-gray-700"
              >Number of Judging Rooms</label
            >
            <input
              type="number"
              id="numJudgingRooms"
              name="numJudgingRooms"
              min="1"
              max="20"
              value="8"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>

          <div>
            <label
              for="startTime"
              class="block text-sm font-medium text-gray-700"
              >Start Time</label
            >
            <input
              type="time"
              id="startTime"
              name="startTime"
              value="08:00"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>
        </div>

        <!-- Team Names Section -->
        <div class="mt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Team Names</h3>
          <div
            id="teamNamesContainer"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
          >
            <!-- Team name inputs will be dynamically added here -->
          </div>
        </div>

        <!-- Generate Button -->
        <div class="mt-6">
          <button
            id="submitButton"
            type="submit"
            class="w-full md:w-auto px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
          >
            Generate Schedule
          </button>
        </div>
      </form>
    </div>
  </div>
</main>

<script>
  // Dynamic form handling
  const configForm = document.getElementById("configForm");
  const numTeamsInput = document.getElementById("numTeams");
  const teamNamesContainer = document.getElementById("teamNamesContainer");
  const successMessage = document.getElementById("successMessage");
  const dismissMessage = document.getElementById("dismissMessage");

  // Set default values
  window.addEventListener("DOMContentLoaded", () => {
    numTeamsInput.value = 32;
    document.getElementById("numTables").value = 4;
    document.getElementById("numJudgingRooms").value = 8;
    document.getElementById("startTime").value = "08:00";

    // Trigger the change event to generate team name fields
    const event = new Event("change");
    numTeamsInput.dispatchEvent(event);
  });

  // Dismiss success message
  dismissMessage.addEventListener("click", function () {
    successMessage.classList.add("hidden");
  });

  numTeamsInput.addEventListener("change", function () {
    const numTeams = parseInt(this.value) || 0;
    teamNamesContainer.innerHTML = "";

    for (let i = 0; i < numTeams; i++) {
      const div = document.createElement("div");
      div.innerHTML = `
        <label for="team${i}" class="block text-sm font-medium text-gray-700">Team ${
        i + 1
      } Name</label>
        <input type="text" id="team${i}" name="teamNames[]" value="Team ${
        i + 1
      }" required
          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
      `;
      teamNamesContainer.appendChild(div);
    }
  });

  configForm.addEventListener("submit", async function (e) {
    e.preventDefault();

    // Find the submit button (either by ID or by type)
    const submitButton =
      document.getElementById("submitButton") ||
      document.querySelector('button[type="submit"]');
    const originalButtonText = submitButton
      ? submitButton.textContent
      : "Generate Schedule";

    if (submitButton) {
      submitButton.textContent = "Generating...";
      submitButton.disabled = true;
    }

    const formData = new FormData(this);
    const config = {
      numTeams: parseInt(formData.get("numTeams")),
      numTables: parseInt(formData.get("numTables")),
      numJudgingRooms: parseInt(formData.get("numJudgingRooms")),
      teamNames: Array.from(formData.getAll("teamNames[]")),
      startTime: formData.get("startTime") || "08:00",
    };

    try {
      const response = await fetch("/api/generate-schedule", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(config),
      });

      if (response.ok) {
        // Show success message
        successMessage.classList.remove("hidden");

        // Scroll to the top to show the success message
        window.scrollTo({ top: 0, behavior: "smooth" });
      } else {
        const data = await response.json();
        alert(
          "Failed to generate schedule: " + (data.error || "Unknown error")
        );
      }
    } catch (error) {
      console.error("Error:", error);
      alert("An error occurred while generating the schedule.");
    } finally {
      // Reset button state
      if (submitButton) {
        submitButton.textContent = originalButtonText;
        submitButton.disabled = false;
      }
    }
  });
</script>

<!-- include footer -->
<%- include('include/_footer') %>
